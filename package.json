{
  "name": "startpage",
  "version": "3.2.3",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --config vite.web.config.ts --host 0.0.0.0",
    "dev:web": "vite --config vite.web.config.ts --host 0.0.0.0",
    "build": "vue-tsc --build && vite build --config vite.web.config.ts",
    "build:web": "vue-tsc --build && vite build --config vite.web.config.ts",
    "cf:d1:create": "wrangler d1 create start_abobb_site",
    "cf:d1:migrate": "wrangler d1 migrations apply start_abobb_site --remote",
    "cf:deploy": "wrangler deploy",
    "preview:web": "vite preview --config vite.web.config.ts --host 0.0.0.0",
    "type-check": "vue-tsc --build",
    "lint:oxlint": "oxlint . --fix -D correctness --ignore-path .gitignore",
    "lint:eslint": "eslint . --fix",
    "lint:style": "stylelint **/*.{css,scss,sass,less,vue,html} --fix --ignore-path .gitignore",
    "lint": "run-s lint:*",
    "format": "oxfmt ."
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "workerd"
    ]
  },
  "dependencies": {
    "@dnd-kit/helpers": "^0.5.0",
    "@dnd-kit/vue": "^0.5.0",
    "@vueuse/components": "^14.3.0",
    "@vueuse/core": "^14.3.0",
    "dayjs": "^1.11.21",
    "dayjs-plugin-lunar": "^1.4.1",
    "element-plus": "^2.14.2",
    "i18next": "^26.3.1",
    "i18next-browser-languagedetector": "^8.2.1",
    "i18next-vue": "^5.4.0",
    "idb": "^8.0.3",
    "pinia": "^3.0.4",
    "vue": "^3.5.38"
  },
  "devDependencies": {
    "@iconify-json/ant-design": "^1.2.5",
    "@iconify-json/fa6-brands": "^1.2.6",
    "@iconify-json/fa6-solid": "^1.2.4",
    "@iconify-json/fluent": "^1.2.50",
    "@iconify-json/ic": "^1.2.4",
    "@material/material-color-utilities": "^0.4.0",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^25.9.3",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/eslint-config-typescript": "^14.8.0",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-oxlint": "^1.69.0",
    "eslint-plugin-vue": "^10.9.2",
    "markdown-exit": "latest",
    "npm-run-all2": "^9.0.2",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "postcss": "^8.5.15",
    "sass-embedded": "^1.100.0",
    "stylelint": "^17.13.0",
    "stylelint-config-recess-order": "^7.7.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-config-standard-vue": "^1.0.0",
    "stylelint-order": "^8.1.1",
    "stylelint-scss": "^7.2.0",
    "typescript": "^6.0.3",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-icons": "^23.0.1",
    "unplugin-vue-components": "^32.1.0",
    "unplugin-vue-markdown": "^32.0.0",
    "vite": "^8.0.16",
    "vite-plugin-i18next-loader": "^4.0.1",
    "vite-svg-loader": "^5.1.1",
    "vue-tsc": "^3.3.5",
    "wrangler": "^4.101.0"
  }
}
